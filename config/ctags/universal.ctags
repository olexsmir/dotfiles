--recurse=yes
--tag-relative=yes

# qualifies MyStruct.MyMethod to MyMethod
#--extras=+q
# full kind names, instead of single letters
--fields=-k+K
# language of the tag (for multi language codebases)
--fields=+l

--languages=-markdown,json,yaml,iniconf,html,css
--sh-kinds=-h

--exclude=.git
--exclude=.jj
--exclude=.docker
--exclude=.tests
--exclude=elm-stuff
--exclude=dist
--exclude=build
--exclude=vendor
--exclude=target
--exclude=node_modules
--exclude=*.min.js
--exclude=*.pb.go
