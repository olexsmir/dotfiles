--recurse=yes
--totals=yes
--tag-relative=yes

# qualifies MyStruct.MyMethod to MyMethod
--extras=+q
# full kind names, instead of single letters
--fields=-k+K
# inheritance/interfaces
--fields=+i
# language of the tag (for multi language codebases)
--fields=+l
# access modifiers (public/private)
--fields=+a
# line number
--fields=+n

--languages=-markdown,json,yaml,iniconf,css,html
--sh-kinds=-h
--Go-kinds=-p
--Odin-kinds=-p

--exclude=.docker
--exclude=.git
--exclude=.jj
--exclude=.nvim.lua
--exclude=.tests
--exclude=Session.vim
--exclude=_site
--exclude=build
--exclude=dist
--exclude=elm-stuff
--exclude=node_modules
--exclude=target
--exclude=testdata
--exclude=vendor
--exclude=*.min.js
--exclude=*.pb.go
