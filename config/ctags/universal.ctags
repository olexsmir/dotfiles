--recurse=yes
--tag-relative=yes
--fields=-k+K
--extras=+q

--languages=-markdown,json,yaml,iniconf,html,css
--sh-kinds=-h

--exclude=.git
--exclude=.jj
--exclude=.docker
--exclude=.tests
--exclude=elm-stuff
--exclude=dist
--exclude=build
--exclude=vendor
--exclude=target
--exclude=node_modules
--exclude=*.min.js
--exclude=*.pb.go
